# Test Engineer Sandbox
# Black-box testing environment — pytest (API) + Playwright (browser E2E)
# Mounts: tests/<side>/ (rw) + contracts/ (ro)
# CANNOT see: backend/ or godot/ source — tests hit running services over the network only
#
# Same image serves both backend-test and frontend-test engineers.
# Both Codex and Claude Code CLIs are installed (arbitrator picks per task).

FROM python:3.12-slim

RUN apt-get update && apt-get install -y \
    git make curl wget gnupg ca-certificates nodejs npm \
    && rm -rf /var/lib/apt/lists/*

# Agent CLIs (arbitrator decides which to invoke via AGENT env var)
RUN npm install -g @anthropic-ai/claude-code @openai/codex || \
    npm install -g @anthropic-ai/claude-code

# Test stack
RUN pip install uv ruff pytest pytest-asyncio httpx pytest-playwright playwright

# Playwright browser + its OS deps (chromium is enough for mobile-web E2E)
RUN playwright install --with-deps chromium

WORKDIR /work

CMD ["claude"]
