# 测试工程师专用镜像 = 通用 agent 镜像 + Playwright（只有 tester 需要浏览器 E2E）。
# backend/frontend 用 Dockerfile.agent，不带 playwright；裁决者跑 GitHub Actions 云端测，也不需要。
# 同样靠 runner.py + env 区分身份，挂载隔离与其它 agent 一致。
FROM python:3.12-slim

# Node.js（claude CLI 需要 18+）
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl git ca-certificates gnupg make \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Claude Code CLI（跑挂进来的 Pro 登录态）
RUN npm install -g @anthropic-ai/claude-code

# runner 依赖 + 测试栈（pytest/httpx）+ Playwright
COPY agent-runner/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt \
    && pip install --no-cache-dir uv ruff pytest pytest-asyncio httpx pytest-playwright playwright

# Playwright 浏览器 + 系统依赖（chromium 足够跑 mobile-web 黑盒 E2E）
RUN playwright install --with-deps chromium

# runner 代码
COPY agent-runner/ /app/
WORKDIR /app

ENV PORT=8080
CMD ["python", "runner.py"]
