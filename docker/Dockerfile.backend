# Backend Agent Sandbox
# Python FastAPI development environment
# Mounts: backend/ (rw) + contracts/ (ro)
# Cannot see: godot/ or any other package

FROM python:3.12-slim

RUN apt-get update && apt-get install -y \
    git make curl wget nodejs npm \
    && rm -rf /var/lib/apt/lists/*

# Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# Common Python dev tools (project deps installed at runtime from mounted pyproject.toml)
RUN pip install uv ruff pytest

WORKDIR /work

# Entrypoint: claude drops into interactive session
CMD ["claude"]
